# .env.example — copy to .env and fill in your values

# RunPod
RUNPOD_API_KEY=your-runpod-api-key
RUNPOD_POD_ID=
RUNPOD_TEMPLATE_ID=your-template-id
RUNPOD_VOLUME_ID=your-volume-id

# Security
QWOPUS_API_KEY=your-api-key-here

# Model
MODEL_REPO=groxaxo/Huihui-Qwen3.5-27B-Claude-4.6-Opus-abliterated-gptq-w4g128
MODEL_PATH=/workspace/models/qwopus-27b
MAX_MODEL_LEN=32768
GPU_MEMORY_UTILIZATION=0.90
