#!/bin/bash
set -a
source "$(dirname "$0")/../.env"
set +a

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

STATE=$(aws ec2 describe-instances \
  --instance-ids $AWS_INSTANCE_ID \
  --region $AWS_REGION \
  --query 'Reservations[0].Instances[0].State.Name' \
  --output text 2>/dev/null)

if [ "$STATE" == "stopped" ]; then
  echo -e "${YELLOW}Already stopped.${NC}"
  exit 0
fi

if [ "$STATE" != "running" ]; then
  echo -e "${RED}Instance state: $STATE${NC}"
  exit 1
fi

echo -e "${YELLOW}Stopping Qwopus...${NC}"
aws ec2 stop-instances \
  --instance-ids $AWS_INSTANCE_ID \
  --region $AWS_REGION > /dev/null 2>&1

echo -n "  Waiting"
while true; do
  STATE=$(aws ec2 describe-instances \
    --instance-ids $AWS_INSTANCE_ID \
    --region $AWS_REGION \
    --query 'Reservations[0].Instances[0].State.Name' \
    --output text 2>/dev/null)
  if [ "$STATE" == "stopped" ]; then
    echo ""
    echo -e "${GREEN}Stopped. Billing paused.${NC}"
    break
  fi
  echo -n "."
  sleep 3
done
