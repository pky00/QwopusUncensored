#!/bin/bash
set -a
source "$(dirname "$0")/../.env"
set +a

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

if [ -z "$RUNPOD_POD_ID" ]; then
  echo -e "${RED}No pod ID found in .env${NC}"
  exit 1
fi

STATUS=$(curl -s "https://api.runpod.io/graphql?api_key=$RUNPOD_API_KEY" \
  -H "Content-Type: application/json" \
  -d "{\"query\": \"{ pod(input: { podId: \\\"$RUNPOD_POD_ID\\\" }) { desiredStatus } }\"}" \
  2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['data']['pod']['desiredStatus'])" 2>/dev/null)

if [ "$STATUS" != "RUNNING" ]; then
  echo -e "${YELLOW}Pod is not running (status: $STATUS)${NC}"
  exit 0
fi

echo -e "${YELLOW}Terminating pod $RUNPOD_POD_ID...${NC}"
curl -s "https://api.runpod.io/graphql?api_key=$RUNPOD_API_KEY" \
  -H "Content-Type: application/json" \
  -d "{\"query\": \"mutation { podTerminate(input: { podId: \\\"$RUNPOD_POD_ID\\\" }) }\"}" \
  > /dev/null 2>&1

echo -e "${GREEN}Pod terminated. Billing stopped.${NC}"
echo -e "${GREEN}Network volume preserved. Run ./client/qwopus to start a new pod.${NC}"

# Clear pod ID since it's terminated
ENV_FILE="$(dirname "$0")/../.env"
sed -i "s/RUNPOD_POD_ID=.*/RUNPOD_POD_ID=/" "$ENV_FILE"
