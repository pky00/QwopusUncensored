#!/bin/bash
set -a
source "$(dirname "$0")/../.env"
set +a

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

STATUS=$(curl -s "https://api.runpod.io/graphql?api_key=$RUNPOD_API_KEY" \
  -H "Content-Type: application/json" \
  -d "{\"query\": \"{ pod(input: { podId: \\\"$RUNPOD_POD_ID\\\" }) { desiredStatus } }\"}" \
  2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['data']['pod']['desiredStatus'])" 2>/dev/null)

if [ "$STATUS" == "EXITED" ]; then
  echo -e "${YELLOW}Already stopped.${NC}"
  exit 0
fi

if [ "$STATUS" != "RUNNING" ]; then
  echo -e "${RED}Pod status: $STATUS${NC}"
  exit 1
fi

echo -e "${YELLOW}Stopping Qwopus...${NC}"
curl -s -X POST "https://api.runpod.io/graphql?api_key=$RUNPOD_API_KEY" \
  -H "Content-Type: application/json" \
  -d "{\"query\": \"mutation { podStop(input: { podId: \\\"$RUNPOD_POD_ID\\\" }) { id } }\"}" \
  > /dev/null 2>&1

echo -n "  Waiting"
for i in $(seq 1 30); do
  STATUS=$(curl -s "https://api.runpod.io/graphql?api_key=$RUNPOD_API_KEY" \
    -H "Content-Type: application/json" \
    -d "{\"query\": \"{ pod(input: { podId: \\\"$RUNPOD_POD_ID\\\" }) { desiredStatus } }\"}" \
    2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['data']['pod']['desiredStatus'])" 2>/dev/null)
  if [ "$STATUS" == "EXITED" ]; then
    echo ""
    echo -e "${GREEN}Stopped. Billing paused.${NC}"
    exit 0
  fi
  echo -n "."
  sleep 3
done

echo ""
echo -e "${YELLOW}Stop requested. Check RunPod console.${NC}"
