#!/bin/bash
set -a
source "$(dirname "$0")/../.env"
set +a

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

echo "Qwopus 27B Status"
echo "================================"

STATUS=$(curl -s "https://api.runpod.io/graphql?api_key=$RUNPOD_API_KEY" \
  -H "Content-Type: application/json" \
  -d "{\"query\": \"{ pod(input: { podId: \\\"$RUNPOD_POD_ID\\\" }) { desiredStatus runtime { uptimeInSeconds gpus { gpuUtilPerc memoryUtilPerc } } } }\"}" \
  2>/dev/null | python3 -c "
import sys, json
d = json.load(sys.stdin)['data']['pod']
print(d['desiredStatus'])
if d.get('runtime') and d['runtime'].get('gpus'):
    g = d['runtime']['gpus'][0]
    print(f\"GPU: {g.get('gpuUtilPerc', '?')}% util, {g.get('memoryUtilPerc', '?')}% VRAM\")
    uptime = d['runtime'].get('uptimeInSeconds', 0)
    print(f\"Uptime: {uptime // 3600}h {(uptime % 3600) // 60}m\")
" 2>/dev/null)

POD_STATUS=$(echo "$STATUS" | head -1)

if [ "$POD_STATUS" == "RUNNING" ]; then
  echo -e "Pod:       ${GREEN}running${NC}"
  echo "$STATUS" | tail -n +2 | while read line; do
    echo -e "           ${GREEN}$line${NC}"
  done
else
  echo -e "Pod:       ${RED}$POD_STATUS${NC}"
  echo "================================"
  exit 0
fi

HEALTH=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 5 \
  "$VLLM_URL/health" 2>/dev/null)
if [ "$HEALTH" == "200" ]; then
  echo -e "Model:     ${GREEN}loaded${NC}"
else
  echo -e "Model:     ${RED}not responding${NC}"
fi

SEARX=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 5 \
  -H "Authorization: Bearer $QWOPUS_API_KEY" \
  "$SEARXNG_URL/health" 2>/dev/null)
if [ "$SEARX" == "200" ]; then
  echo -e "SearXNG:   ${GREEN}ready${NC}"
else
  echo -e "SearXNG:   ${RED}not responding${NC}"
fi

echo "================================"
