#!/bin/bash
set -a
source "$(dirname "$0")/../.env"
set +a

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

echo -e "${GREEN}Starting Qwopus 27B...${NC}"

STATUS=$(curl -s "https://api.runpod.io/graphql?api_key=$RUNPOD_API_KEY" \
  -H "Content-Type: application/json" \
  -d "{\"query\": \"{ pod(input: { podId: \\\"$RUNPOD_POD_ID\\\" }) { desiredStatus runtime { uptimeInSeconds } } }\"}" \
  2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['data']['pod']['desiredStatus'])" 2>/dev/null)

if [ "$STATUS" == "RUNNING" ]; then
  echo -e "${GREEN}Pod already running${NC}"

elif [ "$STATUS" == "EXITED" ]; then
  echo -e "${YELLOW}Pod stopped. Starting...${NC}"
  curl -s -X POST "https://api.runpod.io/graphql?api_key=$RUNPOD_API_KEY" \
    -H "Content-Type: application/json" \
    -d "{\"query\": \"mutation { podResume(input: { podId: \\\"$RUNPOD_POD_ID\\\", gpuCount: 1 }) { id desiredStatus } }\"}" \
    > /dev/null 2>&1

  echo -n "  Waiting for pod"
  for i in $(seq 1 60); do
    STATUS=$(curl -s "https://api.runpod.io/graphql?api_key=$RUNPOD_API_KEY" \
      -H "Content-Type: application/json" \
      -d "{\"query\": \"{ pod(input: { podId: \\\"$RUNPOD_POD_ID\\\" }) { desiredStatus } }\"}" \
      2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['data']['pod']['desiredStatus'])" 2>/dev/null)
    if [ "$STATUS" == "RUNNING" ]; then
      echo ""
      echo -e "${GREEN}  Pod running${NC}"
      break
    fi
    echo -n "."
    sleep 3
  done
else
  echo -e "${RED}Unexpected pod status: $STATUS${NC}"
  exit 1
fi

echo -n "  Waiting for model to load"
for i in $(seq 1 120); do
  HEALTH=$(curl -s -o /dev/null -w "%{http_code}" \
    "$VLLM_URL/health" 2>/dev/null)
  if [ "$HEALTH" == "200" ]; then
    echo ""
    echo -e "${GREEN}  Model loaded${NC}"
    break
  fi
  if [ $i -eq 120 ]; then
    echo ""
    echo -e "${RED}  Model timeout. Check RunPod console logs.${NC}"
    exit 1
  fi
  echo -n "."
  sleep 5
done

SEARX=$(curl -s -o /dev/null -w "%{http_code}" \
  -H "Authorization: Bearer $QWOPUS_API_KEY" \
  "$SEARXNG_URL/health" 2>/dev/null)
if [ "$SEARX" == "200" ]; then
  echo -e "${GREEN}  SearXNG ready${NC}"
else
  echo -e "${YELLOW}  SearXNG not responding${NC}"
fi

echo ""
echo -e "${GREEN}========================================${NC}"
echo -e "${GREEN}  All systems go. Launching OpenCode.   ${NC}"
echo -e "${GREEN}========================================${NC}"
echo ""

if [ -n "$1" ]; then
  cd "$1"
fi

opencode
